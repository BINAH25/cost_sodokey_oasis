# Production environment for docker-compose.prod.yml.
# Copy to ".env" on the server (same directory) and fill in real values.
# Do NOT commit the real .env.

# --- TLS / Caddy ---
# The domain Caddy serves and requests a Let's Encrypt certificate for
# (apex only; www is redirected to it automatically).
DOMAIN=oasismassagewellness.com
# Email Let's Encrypt uses for expiry notices. REQUIRED for real certificates.
ACME_EMAIL=costsimons5@gmail.com

# Django secret key — generate a strong one:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Hostnames Django will serve (comma-separated).
ALLOWED_HOSTS=oasismassagewellness.com,www.oasismassagewellness.com,localhost,127.0.0.1,backend

# Origins trusted for CSRF (admin login over https).
CSRF_TRUSTED_ORIGINS=https://oasismassagewellness.com,https://www.oasismassagewellness.com

# PostgreSQL password (used by both the db service and the backend's DATABASE_URL).
POSTGRES_PASSWORD=change-me-strong-password

# Which image tag to run. "latest" tracks main; pin to a sha-<commit> to lock a build.
IMAGE_TAG=latest

# --- Email (Gmail SMTP) ---
# Business Gmail that sends booking confirmations / feedback notifications.
EMAIL_HOST_USER=Infooasismassagewellness@gmail.com
# Google App Password (16 chars, no spaces) — NOT the normal Gmail password.
# Generate at: Google Account → Security → 2-Step Verification → App passwords.
EMAIL_HOST_PASSWORD=
# Sender shown to recipients.
DEFAULT_FROM_EMAIL=Oasis Massage & Wellness <Infooasismassagewellness@gmail.com>
# Address CC'd on bookings and notified on new feedback.
OWNER_NOTIFICATION_EMAIL=costsimons5@gmail.com
