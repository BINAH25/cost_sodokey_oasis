# Copy to .env for local development. Do NOT commit your real .env.

# Generate a strong key for production, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=dev-insecure-key-change-me-in-production

# True for local dev, False in production.
DEBUG=True

# Comma-separated hostnames Django will serve.
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave unset (or commented) to use the bundled SQLite dev database.
# For production, point at the Postgres service, e.g.:
# DATABASE_URL=postgres://oasis:oasis@db:5432/oasis

# Origins (the frontend) allowed to call this API.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Origins trusted for CSRF in production (your real domain, https).
# CSRF_TRUSTED_ORIGINS=https://oasismassagewellness.com

# Rate limit for anonymous public form submissions.
ANON_THROTTLE_RATE=30/hour

TIME_ZONE=Africa/Accra
